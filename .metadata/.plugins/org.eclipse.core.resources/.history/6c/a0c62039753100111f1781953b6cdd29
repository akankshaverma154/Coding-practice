package com.thread;

public class IbmGccThread {

	public static void main(String[] args) throws InterruptedException {
		// TODO Auto-generated method stub
		
		Thread t1 = new Thread(new Runnable() {
			
			@Override
			public void run() {
				System.out.println("My thread "+Thread.currentThread().getName());
					
			}
		});
		t1.setName("New Worker thread");
		System.out.println("thread name before: "+Thread.currentThread().getName());
		t1.start();
		System.out.println("thread name after : "+Thread.currentThread().getName());
		Thread.sleep(10000);
		
	}

}
