package com.streams;

import java.util.Arrays;
import java.util.Comparator;
import java.util.List;
import java.util.OptionalInt;
import java.util.stream.Collectors;

public class Practice {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		//filter even number
		List<Integer> nums = Arrays.asList(1,2,3,4,5,6);
		List<Integer> even = nums.stream()
				.filter(n-> n%2==0)
				.collect(Collectors.toList());
		System.out.println("even num : "+even);
	
	//Convert list of strings to uppercase
		List<String> names = Arrays.asList("ram", "sam", "john", "Akanksha");
		List<String> upperCase = names.stream()
				.map(e->e.toUpperCase())
				.collect(Collectors.toList());
		System.out.println("Upper case names :"+upperCase);
		
		//sorting in ascending order
		List<String> sortedAsc = names.stream().sorted().collect(Collectors.toList());
		System.out.println("sortedAsc :"+sortedAsc);
		
		List<String> sortedDesc = names.stream().sorted(Comparator.reverseOrder())
				.toList()
		
		//Find sum of all numbers
		List<Integer> sum = Arrays.asList(10,20,30);
		int sums = sum.stream()
				.mapToInt(Integer::intValue)
				.sum();
		System.out.println("sum is :"+sums);
		
		//count strings length > 3
		List<String> list = Arrays.asList("hi","hello","bye","java");
		long count = list.stream()
				.filter(s->s.length()>3)
				.count();
		System.out.println("count : "+count);
	
		//remove duplicates
		List<Integer> duplicate = Arrays.asList(1,2,2,3,4,4);
		List<Integer> distinct = duplicate.stream()
				.distinct()
				.toList();
		System.out.println("distinct :"+distinct);
		
		//find max and min
		List<Integer> nums1 = Arrays.asList(10, 5, 20, 3);
		int max = nums1.stream().max(Integer::compare).get();
		System.out.println("max: "+max);
	
		int min = nums1.stream().min(Integer::compare).get();
		System.out.println("min: "+min);
	}

}
